# Orbit / GitLab Knowledge Graph integration for the blast-radius agent.
# Copy this file to `.env` (which is gitignored) and fill in real values.
# DO NOT commit `.env` or paste your token into chat/logs/PRs.

# Base URL of the Orbit graph_query endpoint (the client appends "/query").
# Example: https://gitlab.com/api/v4/orbit
ORBIT_API_URL=

# GitLab Personal Access Token (read_api scope) used as a Bearer token.
ORBIT_API_TOKEN=

# Project full path that anchors every traversal (must match Orbit's full_path).
ORBIT_PROJECT_PATH=fish763926/gdg-yorku-submission

# Per-request HTTP timeout (seconds) for Orbit queries. The CALLS traversal is the
# heaviest query and scales with repo size; raise this if you see "read operation
# timed out" on fetch_calls. Defaults to 30 when unset.
ORBIT_TIMEOUT=30

# Set to "true" to bypass the network and use injected fixtures (offline/tests).
USE_FAKE_ORBIT=false


# ============================================================
# LLM credentials (ADC-first)
# ============================================================
# Primary auth for BOTH Gemini and Claude is Google Cloud
# Application Default Credentials (ADC) via Vertex AI — one
# credential, no API keys. Anthropic models are served on Vertex,
# so the Claude challenger uses the same ADC as Gemini. Set up once:
#
#   gcloud auth application-default login
#   gcloud config set project <your-project-id>
#
# The API keys below are OPTIONAL fallbacks only — leave blank when
# ADC is configured. DO NOT commit `.env` or paste keys into chat/logs/PRs.

# GCP project that hosts Vertex AI. Required for real (--real) runs.
GOOGLE_CLOUD_PROJECT=
# Vertex region. Must be "global": gemini-3.5-flash and claude-opus-4-8 are
# served only on the global endpoint (regional endpoints like us-central1 404).
GOOGLE_CLOUD_LOCATION=global
# REQUIRED for real runs: forces the google-genai SDK (and ADK) to use Vertex
# AI instead of the AI Studio "Developer API". Without this, a present
# GEMINI_API_KEY routes calls to AI Studio (separate billing) and structured
# output (additionalProperties) is rejected. Keep this "true" for ADC/Vertex.
GOOGLE_GENAI_USE_VERTEXAI=true

# --- Gemini (correctness, coordinator, debate defender) ---
# GA flash on the global endpoint -- fast and good quota/availability. It is
# served ONLY on GOOGLE_CLOUD_LOCATION=global (404 in regional endpoints).
GEMINI_MODEL=gemini-3.5-flash
# LEAVE BLANK for ADC/Vertex. A set key forces the AI Studio Developer API
# path (separate billing; rejects structured output). Only set it if you
# deliberately want the non-Vertex fallback.
GEMINI_API_KEY=

# --- Claude (debate challenger / security hawk) ---
# Opus 4.8, served via Vertex AI on the same ADC credential (no Anthropic key).
CRUCIBLE_CLAUDE_MODEL=claude-opus-4-8
# Cap Claude's reasoning effort to avoid the multi-minute thinking / call
# degradation seen at high effort. One of: low | medium | high | xhigh | max
CRUCIBLE_CLAUDE_EFFORT=medium
# OPTIONAL fallback only — direct Anthropic API key, used if the Vertex/ADC
# path is unavailable.
ANTHROPIC_API_KEY=

# --- Run mode ---
# "true" = offline fake LLM (default; no credentials needed).
# Set "false" (or pass --real) for real Vertex calls.
USE_FAKE_LLM=true
# Enable the defender/challenger security debate loop (or pass --with-debate).
ENABLE_SECURITY_DEBATE=false
