# Orbit / GitLab Knowledge Graph integration for the blast-radius agent.
# Copy this file to `.env` (which is gitignored) and fill in real values.
# DO NOT commit `.env` or paste your token into chat/logs/PRs.

# Base URL of the Orbit graph_query endpoint (the client appends "/query").
# Example: https://gitlab.com/api/v4/orbit
ORBIT_API_URL=

# GitLab Personal Access Token (read_api scope) used as a Bearer token.
ORBIT_API_TOKEN=

# Project full path that anchors every traversal (must match Orbit's full_path).
ORBIT_PROJECT_PATH=fish763926/gdg-yorku-submission

# Set to "true" to bypass the network and use injected fixtures (offline/tests).
USE_FAKE_ORBIT=false
